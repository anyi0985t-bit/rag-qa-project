    {
      "name": "01_기준선_수수료질문",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"답변에 정확한 수수료 숫자가 포함되어야 함\", function () {\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body.answer).to.include(\"40%\");\r",
              "});\r",
              "\r",
              "pm.test(\"상태 코드는 200이어야 함\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"answer 필드가 존재하고 비어있지 않아야 함\", function () {\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body.answer).to.be.a(\"string\").and.not.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
